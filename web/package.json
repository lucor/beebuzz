{
	"name": "beebuzz-web",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.31.0",
	"engines": {
		"node": ">=24.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"scripts": {
		"build": "pnpm -C apps/site run build && pnpm -C apps/hive run build",
		"build:site": "pnpm -C apps/site run build",
		"build:hive": "pnpm -C apps/hive run build",
		"dev:site": "pnpm -C apps/site run dev",
		"dev:hive": "pnpm -C apps/hive run dev",
		"check": "pnpm -C apps/site run check && pnpm -C apps/hive run check",
		"check:site": "pnpm -C apps/site run check",
		"check:hive": "pnpm -C apps/hive run check",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"demo:quickstart": "cd .. && bash scripts/quickstart-demo.sh"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/postcss": "^4.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.6.0",
		"autoprefixer": "^10.5.0",
		"daisyui": "^5.5.19",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"jsdom": "^29.0.2",
		"postcss": "^8.5.10",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"svelte-preprocess": "^6.0.3",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^7.3.2",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@lucide/svelte": "^1.8.0"
	}
}
