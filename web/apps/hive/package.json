{
	"name": "@beebuzz/hive",
	"private": true,
	"version": "0.9.0",
	"type": "module",
	"scripts": {
		"dev": "svelte-kit sync && pnpm run build:sw && vite dev",
		"build": "svelte-kit sync && pnpm run build:sw && vite build",
		"build:sw": "vite build --config vite.config.sw.ts",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
	},
	"dependencies": {
		"@beebuzz/shared": "workspace:*",
		"@noble/hashes": "^2.0.1",
		"age-encryption": "^0.3.0"
	}
}
